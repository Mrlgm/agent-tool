# 火山方舟配置
VOLCENGINE_API_KEY=your-api-key-here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-pro-32k

# 火山引擎 TOS 对象存储配置（图片上传）
TOS_ACCESS_KEY_ID=your-tos-access-key-id
TOS_ACCESS_KEY_SECRET=your-tos-access-key-secret
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=image2code-bucket
TOS_CDN_DOMAIN=https://your-cdn-domain.com

# 火山引擎 Embedding 配置 (多模态)
EMBEDDING_MODEL=your-api-key-here
EMBEDDING_DIMENSIONS=1024

# Tavily 搜索配置
TAVILY_API_KEY=your-tavily-api-key

# ChromaDB 向量数据库配置（需要通过 Docker 启动服务）
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000
VECTOR_DB_COLLECTION=long_term_memory

# 记忆检索配置
MEMORY_TOP_K=3
MEMORY_SIMILARITY_THRESHOLD=0.7

# 服务配置
PORT=3000
NODE_ENV=development
